# =============================================================================
# Bifrost API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before deployment.
#
#   cp .env.example .env
#   vim .env
# =============================================================================

# NewAPI admin token (required)
# Retrieve from: /etc/bifrost/.new-api-admin-token
# Or from Docker: docker exec new-api printenv ADMIN_TOKEN
NEWAPI_ADMIN_TOKEN=your-newapi-admin-token-here

# Bifrost API admin key (for protected management endpoints)
# Used in X-Admin-Key header for admin-only operations
BIFROST_ADMIN_KEY=your-admin-key-here

# Public URL returned to users after registration (must be externally reachable)
# Example: https://ai.your-domain.com
PUBLIC_BASE_URL=

# Registration settings
ALLOW_SELF_REGISTER=true
DEFAULT_QUOTA=100
