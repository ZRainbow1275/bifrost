# =============================================================================
# Bifrost API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before deployment.
#
#   cp .env.example .env
#   vim .env
# =============================================================================

# NewAPI admin token (required)
# Retrieve from: /etc/bifrost/.new-api-admin-token
# Or from Docker: docker exec new-api printenv ADMIN_TOKEN
BIFROST_NEWAPI_ADMIN_TOKEN=your-newapi-admin-token-here

# Bifrost API admin key (for protected management endpoints)
# Used in X-Admin-Key header for admin-only operations
BIFROST_ADMIN_KEY=your-admin-key-here

# Public AI gateway URL returned to users after registration (required)
# This must point at the NewAPI/Caddy gateway domain, not the Bifrost admin panel.
# Example: https://ai.your-domain.com
BIFROST_PUBLIC_BASE_URL=

# NewAPI base URL from the container's perspective (optional)
BIFROST_NEWAPI_BASE_URL=http://host.docker.internal:3000

# Registration settings
BIFROST_ALLOW_SELF_REGISTER=true
BIFROST_DEFAULT_QUOTA=100
BIFROST_MAX_REGISTER_PER_DAY=50
BIFROST_RATE_LIMIT_PER_MINUTE=30

# Registration state persistence
BIFROST_REGISTRATION_STATE_FILE=/data/registration-state.json

# Optional comma-separated CORS allowlist. Leave empty for same-origin only.
# Example: https://ai.your-domain.com
BIFROST_CORS_ALLOW_ORIGINS=
BIFROST_CORS_ALLOW_CREDENTIALS=false
